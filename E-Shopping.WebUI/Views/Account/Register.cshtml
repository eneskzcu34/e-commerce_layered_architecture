<div class="ec-register-page">

    <div class="ec-register-card row g-0">

        <!-- SOL -->
        <div class="col-md-6 ec-register-left">
            <h2>Aramıza Katıl 🎉</h2>
            <p>Hemen kayıt ol, fırsatları kaçırma!</p>
        </div>

        <!-- SAĞ -->
        <div class="col-md-6">

            <div class="ec-register-form">

                <h3 class="ec-register-title">Kayıt Ol</h3>

                <input type="text" placeholder="Ad Soyad" class="ec-input">
                <input type="email" placeholder="E-posta" class="ec-input">
                <input type="password" placeholder="Şifre" class="ec-input">
                <input type="password" placeholder="Şifre Tekrar" class="ec-input">

                <button class="ec-register-btn">Kayıt Ol</button>

                <div class="ec-register-links">
                    Zaten hesabın var mı? <a href="/Account/Login">Giriş Yap</a>
                </div>
            </div>
        </div>
    </div>
</div>
