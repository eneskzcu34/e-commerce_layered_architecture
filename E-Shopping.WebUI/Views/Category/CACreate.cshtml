@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
<style>
    .form-control {
        border: 1px solid #9ca3af;
        border-radius: 8px;
        padding: 10px;
    }

    .form-control:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 0.15rem rgba(37, 99, 235, 0.15);
    }

    .form-label {
        font-weight: 500;
    }
</style>

<div class="form-title mb-3">
    <h5>Kategori Ekle</h5>
</div>

<form>
    <div class="row g-3">

        <div class="col-md-6">
            <label class="form-label">Kategori Adı</label>
            <input type="text" class="form-control" placeholder="Kategori adı girin">
        </div>
        <div class="col-md-6">
            <label class="form-label">Kategori Açıklaması</label>
            <input type="text" class="form-control" placeholder="Kategori açıklaması girin">
        </div>
        <div class="col-12 d-flex justify-content-end gap-2 mt-3">
            <button type="button" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i> İptal
            </button>
            <button class="btn btn-primary">
                <i class="bi bi-check2"></i> Kaydet
            </button>
        </div>

    </div>
</form>