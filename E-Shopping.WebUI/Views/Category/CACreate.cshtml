@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@model CategoryCreateDto

<div class="form-title mb-3">
    <h5>Kategori Ekle</h5>
</div>
<form asp-controller="Category" asp-action="CACreate" method="post">
    <div class="row g-3">
        <div class="col-12">
            <div asp-validation-summary="All" class="text-danger"></div>
        </div>

        <div class="col-md-6">
            <label class="form-label">Kategori Adı</label>
            <input type="text" class="form-control" asp-for="Name" placeholder="Kategori adı girin" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Kategori Açıklaması</label>
            <input type="text" class="form-control" asp-for="Description" placeholder="Kategori açıklaması girin" />
        </div>

        <div class="col-12 d-flex justify-content-end gap-2 mt-3">
            <button type="button" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i> İptal
            </button>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check2"></i> Kaydet
            </button>
        </div>

    </div>
</form>