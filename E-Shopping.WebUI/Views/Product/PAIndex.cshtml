@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@model List<ProductListDto>
<div class="d-flex justify-content-between mb-3">
    <h4>Ürünler</h4>
    <a class="btn btn-primary" asp-controller="Product" asp-action="PACreate">
        <i class="bi bi-plus"></i> Yeni Ürün
    </a>
</div>

<table class="table table-bordered table-hover">
    <thead class="table-light">
        <tr>
            <th>#</th>
            <th>Resim</th>
            <th>Ürün Adı</th>
            <th>Fiyat</th>
            <th>Stok</th>
            <th>Kategori</th>
            <th>Durum</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td style="width: 55px;">
                    <div class="preview-container">
                        <div class="img-preview">
                            <img src="@(string.IsNullOrEmpty(item.MainImageUrl) ? "/images/no-image.png" : item.MainImageUrl)"
                                 alt="@item.Name" />
                        </div>
                    </div>
                </td>
                <td>@item.Name</td>
                <td>₺@item.Price</td>
                <td>@item.Stock</td>
                <td>@item.CategoryName</td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge bg-success">Aktif</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pasif</span>
                    }
                </td>
                <td>
                    <a asp-controller="Product" asp-action="PAUpdate" asp-route-id="@item.Id"
                           class="btn btn-sm btn-warning">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <button class="btn btn-sm btn-danger">
                        <i class="bi bi-trash"></i>
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>