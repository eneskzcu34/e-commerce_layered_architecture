@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}
@model ProductCreateDto
<div class="form-title d-flex justify-content-between align-items-center">
    <h5 class="mb-0">Ürün Ekle</h5>
</div>

<form asp-controller="Product" asp-action="PACreate" method="post" class="mt-4" enctype="multipart/form-data">
    <div class="row g-3">

        <div class="col-12">
            <div asp-validation-summary="All" class="text-danger"></div>
        </div>

        <div class="col-md-6">
            <label class="form-label">Ürün Adı</label>
            <input type="text" class="form-control" asp-for="Name" placeholder="Ürün adı girin" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Fiyat</label>
            <input type="number" class="form-control" asp-for="Price" placeholder="₺" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Stok</label>
            <input type="number" class="form-control" asp-for="Stock" placeholder="Adet" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Kategori</label>
            <select asp-items="Model.Categories" class="form-select" asp-for="CategoryId">
                <option value="">Seçiniz</option>
            </select>
        </div>
        <div class="col-10">
            <label class="form-label">Açıklama</label>
            <textarea class="form-control" rows="8" asp-for="Description" placeholder="Ürün açıklaması..."></textarea>
        </div>
        <div class="col-2 p-4" style="text-align: center;">
            <label class="image-upload-box">
                <i class="bi bi-cloud-upload fs-3"></i>
                <div>Resim seç</div>
                <input type="file" class="d-none" asp-for="Images" />
            </label>
        </div>

       
        <div class="col-12 d-flex justify-content-end gap-2 mt-3">
            <button type="button" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i> İptal
            </button>

            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check2"></i> Kaydet
            </button>
        </div>

    </div>
</form>